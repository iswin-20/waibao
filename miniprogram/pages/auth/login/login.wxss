.auth-switch {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 28rpx;
}

.auth-link {
  color: #f26f8a;
  font-weight: 800;
}

.api-status {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(255, 155, 155, 0.22);
}

.status-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ffb36b;
  flex-shrink: 0;
}

.api-ok .status-dot {
  background: #49b778;
}

.api-bad .status-dot {
  background: #e85b68;
}

.status-main {
  flex: 1;
  min-width: 0;
}

.status-title,
.status-url {
  display: block;
}

.status-title {
  color: #4a3f3f;
  font-size: 24rpx;
  font-weight: 800;
}

.status-url {
  margin-top: 4rpx;
  color: #9a8585;
  font-size: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-action {
  color: #f26f8a;
  font-size: 24rpx;
  font-weight: 800;
}

.demo-box {
  margin-top: 26rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(255, 155, 155, 0.18);
}

.demo-title {
  display: block;
  margin-bottom: 14rpx;
  color: #9a8585;
  font-size: 24rpx;
  text-align: center;
}

.demo-actions {
  display: flex;
  gap: 14rpx;
}

.demo-btn {
  flex: 1;
}
