.tabs {
  display: flex;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 8rpx;
  border-radius: 22rpx;
  background: rgba(255, 228, 228, 0.42);
}

.tab {
  flex: 1;
  height: 68rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8a7474;
  font-size: 24rpx;
  font-weight: 800;
}

.tab-active {
  background: #fff;
  color: #f26f8a;
  box-shadow: 0 8rpx 22rpx rgba(255, 155, 155, 0.16);
}

.wish-card {
  margin-bottom: 0;
}

.wish-main {
  flex: 1;
  min-width: 0;
}

.item-title {
  display: block;
  max-width: 360rpx;
  color: #4a3f3f;
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-desc {
  display: block;
  margin-top: 8rpx;
  color: #9a8585;
  font-size: 24rpx;
  line-height: 1.55;
}

.progress-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
}

.progress-line .progress {
  flex: 1;
}

.wish-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 18rpx;
}

.done-box {
  background: #dcf8e9;
  color: #319163;
}

.wall-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.wall-card {
  min-height: 210rpx;
  margin-bottom: 0;
  text-align: center;
}

.wall-icon {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 16rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ffe4e4, #fff0cd);
  color: #f26f8a;
  font-weight: 900;
}

.wall-title {
  display: block;
  min-height: 74rpx;
  color: #4a3f3f;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.45;
}
