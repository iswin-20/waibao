.weather-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  background: linear-gradient(135deg, rgba(255, 228, 228, 0.7), rgba(255, 240, 205, 0.56));
}

.weather-title,
.weather-desc,
.item-title,
.item-desc {
  display: block;
}

.weather-title {
  color: #3f3434;
  font-size: 30rpx;
  font-weight: 900;
}

.weather-desc,
.item-desc {
  margin-top: 8rpx;
  color: #9a8585;
  font-size: 24rpx;
  line-height: 1.5;
}

.recommend-btn {
  width: 168rpx;
  flex-shrink: 0;
}

.model-stage {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.model {
  position: relative;
  width: 260rpx;
  height: 520rpx;
  flex-shrink: 0;
}

.hair-back,
.hair-front,
.head {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.hair-back {
  z-index: 1;
}

.head {
  top: 26rpx;
  z-index: 3;
  width: 82rpx;
  height: 82rpx;
  overflow: hidden;
  border-radius: 50%;
  background: #ffe0cf;
  box-shadow: 0 8rpx 22rpx rgba(91, 68, 58, 0.08);
}

.hair-front {
  top: -14rpx;
  z-index: 4;
  background: #5b4038;
}

.neck {
  position: absolute;
  left: 50%;
  top: 102rpx;
  z-index: 2;
  width: 34rpx;
  height: 38rpx;
  transform: translateX(-50%);
  border-radius: 0 0 14rpx 14rpx;
  background: #ffe0cf;
}

.arm {
  position: absolute;
  z-index: 1;
  width: 30rpx;
  height: 168rpx;
  border-radius: 22rpx;
  background: #ffe0cf;
}

.body {
  position: relative;
  top: 132rpx;
  z-index: 3;
  margin: 0 auto;
  background: #f4e8e3;
  box-shadow: inset 0 -10rpx 20rpx rgba(139, 104, 92, 0.08);
}

.legs {
  position: relative;
  z-index: 2;
  margin: 142rpx auto 0;
  background: #eee3de;
  box-shadow: inset 0 -10rpx 18rpx rgba(139, 104, 92, 0.07);
}

.feet {
  position: relative;
  z-index: 3;
  width: 184rpx;
  height: 54rpx;
  margin: 10rpx auto 0;
}

.model-female .hair-back {
  top: 14rpx;
  width: 112rpx;
  height: 142rpx;
  border-radius: 60rpx 60rpx 48rpx 48rpx;
  background: #5b4038;
}

.model-female .hair-front {
  width: 94rpx;
  height: 46rpx;
  border-radius: 50% 50% 44% 44%;
}

.model-female .arm-left {
  top: 150rpx;
  left: 56rpx;
  transform: rotate(8deg);
}

.model-female .arm-right {
  top: 150rpx;
  right: 56rpx;
  transform: rotate(-8deg);
}

.model-female .body {
  width: 148rpx;
  height: 184rpx;
  border-radius: 54rpx 54rpx 34rpx 34rpx;
}

.model-female .legs {
  width: 144rpx;
  height: 162rpx;
  border-radius: 22rpx 22rpx 50rpx 50rpx;
}

.model-male .hair-front {
  top: -8rpx;
  width: 86rpx;
  height: 36rpx;
  border-radius: 38rpx 38rpx 22rpx 22rpx;
}

.model-male .arm-left {
  top: 150rpx;
  left: 42rpx;
  transform: rotate(5deg);
}

.model-male .arm-right {
  top: 150rpx;
  right: 42rpx;
  transform: rotate(-5deg);
}

.model-male .body {
  width: 172rpx;
  height: 186rpx;
  border-radius: 38rpx 38rpx 24rpx 24rpx;
}

.model-male .legs {
  width: 164rpx;
  height: 164rpx;
  border-radius: 20rpx 20rpx 42rpx 42rpx;
}

.wear {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
}

.wear-top {
  top: 4rpx;
  width: 194rpx;
  height: 178rpx;
}

.wear-jacket {
  top: -4rpx;
  width: 218rpx;
  height: 194rpx;
  z-index: 4;
}

.wear-bottom {
  top: -12rpx;
  width: 188rpx;
  height: 190rpx;
}

.wear-shoes {
  top: 0;
  width: 188rpx;
  height: 62rpx;
}

.model-male .wear-top {
  width: 214rpx;
}

.model-male .wear-jacket {
  width: 232rpx;
}

.model-male .wear-bottom {
  width: 202rpx;
}

.model-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  height: 42rpx;
  margin-bottom: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 143, 163, 0.14);
  color: #ff7d96;
  font-size: 22rpx;
  font-weight: 900;
}

.selected-note {
  flex: 1;
  min-width: 0;
}

.item-title {
  color: #4a3f3f;
  font-size: 30rpx;
  font-weight: 900;
}

.rec-card {
  background: #fffdf8;
}

.rec-summary {
  display: block;
  margin-top: 14rpx;
  color: #4a3f3f;
  font-size: 28rpx;
  line-height: 1.65;
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 16rpx;
}

.tip {
  color: #8a7474;
  font-size: 24rpx;
}

.compact-empty {
  padding: 22rpx 0;
}

.wardrobe-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.cloth-card {
  min-width: 0;
  padding: 12rpx;
  border: 2rpx solid transparent;
  border-radius: 20rpx;
  background: rgba(255, 228, 228, 0.24);
}

.cloth-selected {
  border-color: #ff8fa3;
  background: rgba(255, 228, 228, 0.6);
}

.cloth-img {
  width: 100%;
  height: 150rpx;
  border-radius: 16rpx;
  background: #fff;
}

.cloth-name {
  display: block;
  margin-top: 10rpx;
  color: #4a3f3f;
  font-size: 23rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cloth-meta {
  display: block;
  margin-top: 4rpx;
  color: #a59090;
  font-size: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-img {
  width: 100%;
  height: 360rpx;
  margin-bottom: 24rpx;
  border-radius: 22rpx;
  background: #fff;
}
