.calendar-card {
  padding-top: 22rpx;
}

.calendar-head {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 128rpx 1fr;
  align-items: center;
  min-height: 82rpx;
  margin-bottom: 18rpx;
}

.year-label {
  position: absolute;
  top: 0;
  right: 4rpx;
  color: #9a8585;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 28rpx;
}

.nav-zone {
  display: flex;
  align-items: center;
  height: 82rpx;
  min-width: 0;
}

.nav-zone-left {
  justify-content: center;
  padding-right: 34rpx;
}

.nav-zone-right {
  justify-content: center;
  padding-left: 34rpx;
}

.nav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  background: rgba(255, 228, 228, 0.52);
  color: #f26f8a;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 46rpx;
}

.month-title {
  display: block;
  position: relative;
  z-index: 1;
  color: #4a3f3f;
  font-size: 36rpx;
  font-weight: 900;
  width: 128rpx;
  text-align: center;
}

.week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.week-day {
  padding: 10rpx 0;
  text-align: center;
  color: #a59090;
  font-size: 22rpx;
  font-weight: 800;
}

.calendar-grid {
  gap: 8rpx;
}

.day-cell {
  position: relative;
  height: 78rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4a3f3f;
  font-size: 26rpx;
  font-weight: 700;
}

.day-muted {
  color: rgba(154, 133, 133, 0.3);
}

.day-today {
  border: 3rpx solid #ff8fa3;
}

.day-period {
  background: linear-gradient(135deg, #ff8fa3, #ffb36b);
  color: #fff;
  border: 0;
}

.legend {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(255, 155, 155, 0.22);
}

.legend-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
}

.period-dot {
  background: linear-gradient(135deg, #ff8fa3, #ffb36b);
}

.today-dot {
  border: 3rpx solid #ff8fa3;
}

.predict-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 0 10rpx;
}

.predict-date {
  color: #f26f8a;
  font-size: 40rpx;
  font-weight: 900;
}

.compact-empty {
  padding: 20rpx 0;
}

.item-title {
  display: block;
  color: #4a3f3f;
  font-size: 28rpx;
  font-weight: 800;
}

.item-desc {
  display: block;
  margin-top: 8rpx;
  color: #9a8585;
  font-size: 24rpx;
  line-height: 1.55;
}

.tip-card {
  background: #fff9e8;
  border-color: #ffe4ae;
}

.picker-value {
  color: #4a3f3f;
  line-height: 44rpx;
}
