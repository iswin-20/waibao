<view class="page">
  <view wx:if="{{loading}}" class="empty">
    <text class="empty-title">正在查看状态...</text>
  </view>

  <block wx:else>
    <view wx:if="{{!status}}" class="card empty">
      <text class="empty-title">尚未绑定另一半</text>
      <text class="empty-desc">去“我的”页面输入邀请码或生成邀请码后再回来。</text>
      <button class="btn btn-primary inline-btn" bindtap="goProfile">去绑定</button>
    </view>

    <block wx:else>
      <view class="card card-soft">
        <view class="row gap-16">
          <view class="avatar">{{partnerInitial}}</view>
          <view>
            <text class="hello-title">{{status.user.nickname || '小宝'}}</text>
            <text class="muted">今天也记得温柔一点靠近。</text>
          </view>
        </view>
      </view>

      <view class="stats-grid">
        <view class="card stat-card">
          <text class="stat-value">{{status.loveDays || 0}}</text>
          <text class="tiny">在一起的天数</text>
        </view>
        <view class="card stat-card">
          <text class="stat-value">{{moodText}}</text>
          <text class="tiny">最近心情</text>
        </view>
      </view>

      <view wx:if="{{status.periodStatus === 'period'}}" class="card period-alert">
        <text class="item-title">她可能正在例假期</text>
        <text class="item-desc">今天可以多一点耐心，多提醒热水、休息和保暖。</text>
      </view>

      <view class="card">
        <view class="section-header">
          <text class="section-title">今日建议</text>
        </view>
        <text class="advice">{{dailyTip}}</text>
      </view>

      <view class="card">
        <view class="section-header">
          <text class="section-title">近期心愿</text>
          <text class="section-subtitle" bindtap="goWishes">查看</text>
        </view>
        <view wx:if="{{wishes.length === 0}}" class="empty compact-empty">
          <text class="empty-title">还没有心愿</text>
        </view>
        <view wx:else class="list">
          <view wx:for="{{wishes}}" wx:key="id" class="list-item">
            <view class="row-between">
              <text class="item-title">{{item.title}}</text>
              <text class="badge">{{item.categoryText}}</text>
            </view>
            <view class="progress-line">
              <view class="progress">
                <view class="progress-bar" style="width: {{item.progress}}%;"></view>
              </view>
              <text class="tiny">{{item.progress}}%</text>
            </view>
          </view>
        </view>
      </view>

      <view class="card">
        <view class="section-header">
          <text class="section-title">重要日子</text>
        </view>
        <view wx:if="{{dates.length === 0}}" class="empty compact-empty">
          <text class="empty-title">暂无临近日子</text>
        </view>
        <view wx:else class="list">
          <view wx:for="{{dates}}" wx:key="id" class="list-item row-between">
            <view>
              <text class="item-title">{{item.title}}</text>
              <text class="item-desc">{{item.dateText}}</text>
            </view>
            <text class="badge badge-yellow">{{item.daysText}}</text>
          </view>
        </view>
      </view>
    </block>
  </block>

  <tabbar active="partner-home" />
</view>
