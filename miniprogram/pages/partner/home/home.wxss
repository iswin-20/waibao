.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff8fa3, #ffb36b);
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
}

.hello-title {
  display: block;
  color: #3f3434;
  font-size: 38rpx;
  font-weight: 900;
}

.inline-btn {
  width: 240rpx;
  margin: 24rpx auto 0;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.stat-card {
  margin-bottom: 0;
  text-align: center;
}

.stat-value {
  display: block;
  color: #f26f8a;
  font-size: 42rpx;
  font-weight: 900;
}

.period-alert {
  background: #fff3f4;
}

.advice {
  display: block;
  color: #5d4e4e;
  font-size: 28rpx;
  line-height: 1.7;
}

.compact-empty {
  padding: 20rpx 0;
}

.item-title {
  display: block;
  color: #4a3f3f;
  font-size: 28rpx;
  font-weight: 900;
}

.item-desc {
  display: block;
  margin-top: 8rpx;
  color: #9a8585;
  font-size: 24rpx;
}

.progress-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.progress-line .progress {
  flex: 1;
}
