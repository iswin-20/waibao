.wish-card {
  margin-bottom: 0;
}

.wish-main {
  flex: 1;
  min-width: 0;
}

.item-title {
  display: block;
  max-width: 360rpx;
  color: #4a3f3f;
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-desc {
  display: block;
  margin-top: 8rpx;
  color: #9a8585;
  font-size: 24rpx;
  line-height: 1.55;
}

.progress-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
}

.progress-line .progress {
  flex: 1;
}

.claim-btn {
  width: 200rpx;
  margin-top: 18rpx;
}

.claim-text {
  display: block;
  margin-top: 16rpx;
}
