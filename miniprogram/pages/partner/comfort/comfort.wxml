<view class="page">
  <view class="section-header">
    <view>
      <text class="section-title">哄哄歪宝</text>
      <text class="section-subtitle">发送一条温柔的关心</text>
    </view>
  </view>

  <view class="pill-scroll">
    <view wx:for="{{categories}}" wx:key="*this" class="pill {{activeCategory === item ? 'pill-active' : ''}}" data-category="{{item}}" bindtap="chooseCategory">{{item}}</view>
  </view>

  <view class="card ai-card">
    <text class="item-title">AI 生成一句关心</text>
    <text class="item-desc">根据她最近的心情状态，由 DeepSeek 帮你组织一句更贴合当下的话。</text>
    <button class="btn btn-primary ai-btn" loading="{{sendingId === 'ai'}}" bindtap="sendAiComfort">生成并发送</button>
  </view>

  <view class="list">
    <view wx:for="{{messages}}" wx:key="id" class="card message-card">
      <text class="badge">{{item.category}}</text>
      <text class="message-text">{{item.text}}</text>
      <button class="btn btn-primary btn-small send-btn" data-id="{{item.id}}" loading="{{sendingId === item.id}}" bindtap="sendComfort">发送关心</button>
    </view>
  </view>

  <tabbar active="partner-comfort" />
</view>
