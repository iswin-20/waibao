.pill-scroll {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.message-card {
  margin-bottom: 0;
}

.ai-card {
  background: linear-gradient(135deg, rgba(255, 228, 228, 0.7), rgba(255, 240, 205, 0.5));
}

.item-title {
  display: block;
  color: #4a3f3f;
  font-size: 30rpx;
  font-weight: 900;
}

.item-desc {
  display: block;
  margin-top: 8rpx;
  color: #9a8585;
  font-size: 24rpx;
  line-height: 1.55;
}

.message-text {
  display: block;
  margin-top: 18rpx;
  color: #4a3f3f;
  font-size: 28rpx;
  line-height: 1.65;
}

.send-btn {
  width: 200rpx;
  margin-top: 22rpx;
}

.ai-btn {
  margin-top: 22rpx;
}
