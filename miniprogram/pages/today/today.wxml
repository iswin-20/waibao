<view class="page">
  <view wx:if="{{loading}}" class="empty">
    <text class="empty-title">正在准备今日页面...</text>
  </view>

  <block wx:else>
    <view class="card card-soft">
      <view class="row gap-16">
        <view class="icon-box">心</view>
        <view class="column gap-12">
          <text class="hello-title">{{greeting}}，{{user.nickname || '小宝'}}</text>
          <text class="muted">{{encouragement}}</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view wx:if="{{!couple || couple.status === 'none'}}" class="empty compact-empty">
        <text class="empty-title">尚未绑定另一半</text>
        <text class="empty-desc">去“我的”页面生成邀请码，邀请另一半加入小窝。</text>
        <button class="btn btn-ghost btn-small inline-btn" bindtap="goProfile">去绑定</button>
      </view>
      <view wx:elif="{{couple.status === 'pending'}}" class="column gap-16">
        <view class="section-header no-margin">
          <view>
            <text class="section-title">等待绑定</text>
            <text class="section-subtitle">把邀请码发给另一半</text>
          </view>
          <text class="badge badge-yellow">{{couple.bindCode}}</text>
        </view>
        <button class="btn btn-secondary btn-small" bindtap="copyBindCode">复制邀请码</button>
      </view>
      <view wx:else class="love-card">
        <text class="muted">我们已经恋爱</text>
        <view class="love-days">{{loveDays}}<text class="love-unit">天</text></view>
        <text class="tiny">和 {{couple.partner.nickname || '另一半'}} 绑定中</text>
      </view>
    </view>

    <view class="card">
      <view class="section-header">
        <text class="section-title">重要日子</text>
        <text class="section-subtitle">{{dates.length}} 个</text>
      </view>
      <view wx:if="{{dates.length === 0}}" class="empty compact-empty">
        <text class="empty-title">还没有临近的纪念日</text>
        <text class="empty-desc">可以在“我的”页面添加生日、纪念日和重要安排。</text>
      </view>
      <view wx:else class="list">
        <view wx:for="{{dates}}" wx:key="id" class="list-item row-between">
          <view>
            <text class="item-title">{{item.title}}</text>
            <text class="item-desc">{{item.dateText}}{{item.repeatType === 'yearly' ? ' · 每年' : ''}}</text>
          </view>
          <text class="badge {{item.close ? 'badge-yellow' : ''}}">{{item.daysText}}</text>
        </view>
      </view>
    </view>

    <view class="card" bindtap="goWeather">
      <view class="row-between">
        <view class="row gap-16">
          <view class="icon-box">天</view>
          <view>
            <view class="weather-line">
              <text class="weather-temp">{{weather.tempMax}}°</text>
              <text class="muted"> / {{weather.tempMin}}° {{weather.weather}}</text>
            </view>
            <text class="item-desc">{{weatherAdvice}}</text>
          </view>
        </view>
        <text class="tiny">详情</text>
      </view>
    </view>

    <view class="card">
      <view class="section-header">
        <text class="section-title">今日待办</text>
        <text class="section-subtitle">{{todos.length}} 项</text>
      </view>
      <view wx:if="{{todos.length === 0}}" class="empty compact-empty">
        <text class="empty-title">今天任务都完成啦</text>
        <text class="empty-desc">给自己留一点休息时间。</text>
      </view>
      <view wx:else class="list">
        <view wx:for="{{todos}}" wx:key="id" class="todo-item">
          <view class="todo-check" data-id="{{item.id}}" bindtap="completeTodo">{{item.completing ? '...' : ''}}</view>
          <view class="todo-content">
            <text class="item-title">{{item.title}}</text>
            <text wx:if="{{item.description}}" class="item-desc">{{item.description}}</text>
          </view>
          <text wx:if="{{item.priority === 'urgent' || item.priority === 'high'}}" class="badge badge-yellow">{{item.priorityText}}</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="section-header">
        <text class="section-title">今日心情</text>
        <text class="section-subtitle" bindtap="goDiary">日记本</text>
      </view>

      <view wx:if="{{todayDiary && todayDiary.content}}" class="column gap-16">
        <view class="diary-box">
          <text class="diary-content">{{todayDiary.content}}</text>
          <text wx:if="{{todayDiary.moodScore}}" class="tiny">心情：{{todayDiary.moodText}}</text>
        </view>
        <view wx:if="{{analysis && analysis.comfortText}}" class="comfort-box">
          <text class="item-title">给你的安慰</text>
          <text class="item-desc">{{analysis.comfortText}}</text>
        </view>
      </view>

      <view wx:else class="column gap-16">
        <text class="muted">今天心情怎么样？</text>
        <view class="mood-row">
          <view wx:for="{{moodOptions}}" wx:key="score" class="mood-option {{selectedMood === item.score ? 'mood-active' : ''}}" data-score="{{item.score}}" bindtap="selectMood">
            <text class="mood-icon">{{item.icon}}</text>
            <text class="mood-label">{{item.label}}</text>
          </view>
        </view>
        <textarea class="textarea" value="{{content}}" placeholder="分享今天的心情和故事..." bindinput="onContentInput" />
        <button class="btn btn-primary {{submitting ? 'btn-disabled' : ''}}" loading="{{submitting}}" bindtap="submitMood">记录心情</button>
      </view>
    </view>
  </block>

  <tabbar active="today" />
</view>
