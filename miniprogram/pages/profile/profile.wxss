.profile-head {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  margin: 18rpx 0 36rpx;
}

.avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff8fa3, #ffb36b);
  color: #fff;
  font-size: 46rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 34rpx rgba(255, 143, 163, 0.26);
}

.profile-name {
  color: #3f3434;
  font-size: 36rpx;
  font-weight: 900;
}

.setting-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 155, 155, 0.2);
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 12rpx 30rpx rgba(255, 155, 155, 0.1);
}

.setting-main {
  flex: 1;
  min-width: 0;
}

.item-title {
  display: block;
  color: #4a3f3f;
  font-size: 28rpx;
  font-weight: 900;
}

.item-desc {
  display: block;
  margin-top: 8rpx;
  color: #9a8585;
  font-size: 24rpx;
  line-height: 1.5;
}

.soft-setting {
  background: #fffdf8;
}

.danger-setting {
  background: #fff4f4;
  border-color: #ffd6d6;
}

.danger-box {
  background: #ffe0e0;
  color: #d84f5f;
}

.danger-text {
  color: #d84f5f;
}

.picker-value {
  color: #4a3f3f;
  line-height: 44rpx;
}

.compact-empty {
  padding: 20rpx 0;
}

.date-list {
  max-height: 360rpx;
}

.form-split {
  height: 1rpx;
  margin: 26rpx 0;
  background: rgba(255, 155, 155, 0.22);
}

.couple-box {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.bind-code {
  padding: 28rpx;
  border-radius: 22rpx;
  background: rgba(255, 228, 228, 0.42);
  color: #f26f8a;
  text-align: center;
  font-size: 42rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
}

.bind-btn {
  margin-top: 18rpx;
}
