# Copy this file to .env.production on your server and fill real values.

APP_PORT=3000

# Use a long random value in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# AI
DEEPSEEK_API_KEY=replace-with-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Amap Web Service key.
WEATHER_API_KEY=replace-with-your-amap-key

# Optional email settings.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
