# Copy this file to .env.production on your server and fill real values.

APP_PORT=3000

# Use a long random value in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Use false when deploying on plain HTTP such as http://43.128.155.3:39000.
# Change to true after switching to HTTPS domain.
COOKIE_SECURE=false

# AI
DEEPSEEK_API_KEY=replace-with-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Amap Web Service key.
WEATHER_API_KEY=replace-with-your-amap-key

# Gmail SMTP. Use a Gmail app password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
APP_URL=http://43.128.155.3:39000
